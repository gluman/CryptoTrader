# ============================================
# CryptoTrader Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Binance Exchange
# ============================================
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_TESTNET=false

# ============================================
# Bybit Exchange
# ============================================
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret
BYBIT_TESTNET=false

# ============================================
# Bitfinex Exchange
# ============================================
BITFINEX_API_KEY=your_bitfinex_api_key
BITFINEX_API_SECRET=your_bitfinex_api_secret
BITFINEX_TESTNET=false

# ============================================
# CoinEx Exchange
# ============================================
COINEX_ACCESS_ID=your_coinex_access_id
COINEX_SECRET_KEY=your_coinex_secret_key

# ============================================
# Telegram Bot
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=

# ============================================
# CryptoRank API
# ============================================
CRYPTORANK_API_KEY=your_cryptorank_api_key

# ============================================
# CoinDesk API
# ============================================
COINDESK_API_KEY=your_coindesk_api_key

# ============================================
# OpenRouter LLM
# ============================================
OPENROUTER_API_KEY=your_openrouter_api_key

# ============================================
# PostgreSQL
# ============================================
POSTGRES_HOST=192.168.0.194
POSTGRES_PORT=5432
POSTGRES_DB=cryptotrader
POSTGRES_USER=cryptotrader
POSTGRES_PASSWORD=cryptotrader123

# ============================================
# RAGFlow
# ============================================
RAGFLOW_BASE_URL=http://192.168.0.156:9380
RAGFLOW_API_KEY=your_ragflow_api_key

# ============================================
# AnythingLLM
# ============================================
ANYTHINGLLM_BASE_URL=http://192.168.0.133:3001
ANYTHINGLLM_API_KEY=
